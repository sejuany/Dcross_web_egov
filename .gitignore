.svn/

# =========================================
# Java / Spring Boot
# =========================================
target/
*.class
*.jar
*.war
*.ear
*.nar

# Maven
.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# =========================================
# 민감 정보 (DB 접속 정보 등) - 절대 올리지 마세요!
# =========================================
# 로컬 환경 전용 설정 파일 (비밀번호, IP 등)
src/main/resources/application-local.yml
src/main/resources/application-prod.yml

# =========================================
# IntelliJ IDEA / Eclipse
# =========================================
.idea/
*.iws
*.iml
*.ipr
.classpath
.project
.settings/
.factorypath

# =========================================
# Eclipse eGovFrame
# =========================================
.metadata/

# =========================================
# Node.js / React (프론트엔드)
# =========================================
src/main/frontend/node_modules/
src/main/frontend/build/
src/main/frontend/.env.local
src/main/frontend/.env.development.local
src/main/frontend/.env.test.local
src/main/frontend/.env.production.local
src/main/frontend/npm-debug.log*
src/main/frontend/yarn-debug.log*
src/main/frontend/yarn-error.log*

# React 빌드 결과물 (Spring Boot static 폴더) - 빌드 후 자동 생성됨
src/main/resources/static/

# =========================================
